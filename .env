# .env - Production environment variables

# Database
DATABASE_PATH=/data/trading_agent.db
DATABASE_POOL_SIZE=10

# Risk Management
MAX_POSITION_SIZE=100000
MAX_DAILY_LOSS=10000
RISK_PER_TRADE=0.02
STOP_LOSS_DEFAULT=0.02
TAKE_PROFIT_DEFAULT=0.04
MAX_DRAWDOWN=0.15
MAX_LEVERAGE=2.0

# Trading
DEFAULT_ORDER_TYPE=market
DEFAULT_TIME_IN_FORCE=GTC
MIN_VOLUME_THRESHOLD=1000
MAX_SLIPPAGE=0.01

# AI Model
OLLAMA_MODEL=llama2
OLLAMA_HOST=http://localhost:11434
AI_ANALYSIS_INTERVAL=3600
AI_CONFIDENCE_THRESHOLD=70

# Webhook
DEFAULT_WEBHOOK_URL=
WEBHOOK_TIMEOUT=10
WEBHOOK_MAX_RETRIES=3
WEBHOOK_SECRET=your-webhook-secret-here

# Alerts
ALERT_CHECK_INTERVAL=5
MAX_ALERTS_PER_SYMBOL=10

# Monitoring
METRICS_PORT=9090
HEALTH_CHECK_PORT=8080
DASHBOARD_PORT=8765
PERFORMANCE_REPORT_INTERVAL=86400

# API Keys (for real market data)
BINANCE_API_KEY=
BINANCE_API_SECRET=
ALPACA_API_KEY=
ALPACA_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Redis (for distributed deployments)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/trading-agent/trading_agent.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5